{
  "name": "ton-payment-gateway",
  "version": "1.0.0",
  "description": "JavaScript/TypeScript SDK for TonPaymentGateway – TON blockchain payments in minutes",
  "type": "module",
  "main": "./dist/index.umd.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js"
    }
  },
  "scripts": {
    "build": "tsc && vite build",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ton",
    "blockchain",
    "payment",
    "gateway",
    "tonconnect"
  ],
  "license": "MIT",
  "dependencies": {
    "@tonconnect/ui": "^2.0.7"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vite": "^5.2.8",
    "vite-plugin-dts": "^4.5.4"
  }
}
