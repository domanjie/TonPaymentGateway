{
  "name": "ton-payment-gateway-root",
  "version": "1.0.0",
  "private": true,
  "description": "TonPaymentGateway Monorepo",
  "scripts": {
    "dev:api": "cd backend/api-server && npm run dev",
    "dev:listener": "cd backend/blockchain-listener && npm run dev",
    "dev:webhook": "cd backend/webhook-worker && npm run dev",
    "dev:miniapp": "cd miniapp/telegram-dashboard && npm run dev",
    "install:all": "npm install --prefix backend/api-server && npm install --prefix backend/blockchain-listener && npm install --prefix backend/webhook-worker && npm install --prefix miniapp/telegram-dashboard",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "workspaces": [
    "backend/api-server",
    "backend/blockchain-listener",
    "backend/webhook-worker",
    "miniapp/telegram-dashboard",
    "sdk/js-sdk"
  ]
}
