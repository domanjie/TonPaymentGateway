# ===========================================
# TonPaymentGateway Environment Variables
# ===========================================

# ---- Database ----
DATABASE_URL=postgresql://postgres:password@localhost:5432/ton_payment_gateway
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=ton_payment_gateway

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- API Server ----
API_PORT=3000
API_HOST=0.0.0.0
JWT_SECRET=your_jwt_secret_change_this_in_production
NODE_ENV=development

# ---- TON Blockchain ----
TON_RPC_URL=https://toncenter.com/api/v2
TON_API_KEY=your_toncenter_api_key
TON_NETWORK=mainnet
# Polling interval in milliseconds
BLOCKCHAIN_POLL_INTERVAL=10000

# ---- Webhook ----
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_BASE_DELAY=1000

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_USERNAME=your_bot_username

# ---- Agents ----
AGENT_FRAUD_THRESHOLD=10
AGENT_RECONCILIATION_INTERVAL=3600000

# ---- Frontend (Mini App) ----
VITE_API_URL=http://localhost:3000
VITE_TON_NETWORK=mainnet
